#!/usr/bin/env bash

SECONDS_UNTIL_SCREENSAVER=$(cat "$XDG_CONFIG_HOME/dotfiles/seconds-until-screensaver")
xset s default
xset s "$SECONDS_UNTIL_SCREENSAVER"

SECONDS_UNTIL_BLANK_SCREEN=$((SECONDS_UNTIL_SCREENSAVER - 60))
xset +dpms
xset dpms "$SECONDS_UNTIL_BLANK_SCREEN" "$SECONDS_UNTIL_BLANK_SCREEN" "$SECONDS_UNTIL_BLANK_SCREEN"
